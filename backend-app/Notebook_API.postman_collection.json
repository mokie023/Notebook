        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Test@1234567\",\n  \"password_confirmation\": \"Test@1234567\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}/auth/register",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "  var jsonData = pm.response.json();",
                                    "  pm.environment.set(\"token\", jsonData.data.token);",
                                    "  pm.test(\"✅ Registered & token saved\", function () {",
                                    "    pm.expect(jsonData.success).to.equal(true);",
                                    "  });",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Test@1234567\"\n}"
                        },
                        "url": {
                            "raw": "{{BASE_URL}}/auth/login",
                            "host": [
                                "{{BASE_URL}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  var jsonData = pm.response.json();",
                                    "  pm.environment.set(\"token\", jsonData.data.token);",
                                    "  pm.test(\"✅ Logged in & token saved\", function () {",
                                    "    pm.expect(jsonData.success).to.equal(true);",
                                    "  });",
                                    "}"
                                ]
                            }
                        }
                    ]
